-- =================== ADDED FEATURES ===================

local function findButton(textSubstring)
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("TextButton") and string.find(string.lower(obj.Text or ""), string.lower(textSubstring)) then
            return obj
        end
    end
    return nil
end

local function clickButton(button)
    if button and button:IsA("TextButton") and button.Visible then
        button:Click()
        return true
    end
    return false
end

local features = {
    autoCash = false,
    autoReset = false,
    autoRune = false,
    autoStarterTree = false,
    autoTree3x = false
}

local function improveAntiCheat()
    local antiCheatRemotes = {"AntiCheat", "CheatDetected", "BanWave"}
    for _, remoteName in pairs(antiCheatRemotes) do
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild(remoteName)
        if remote then remote:Destroy() end
    end
    if getrenv and getrenv()._G then
        getrenv()._G.print = function() end
    end
    local ts = game:GetService("TelemetryService")
    if ts then ts:SetTelemetryEnabled(false) end
end

